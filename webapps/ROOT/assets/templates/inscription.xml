<?xml version="1.0" encoding="utf-8"?>
<kiln:root xmlns:tei="http://www.tei-c.org/ns/1.0"
           xmlns:xi="http://www.w3.org/2001/XInclude"
           xmlns:kiln="http://www.kcl.ac.uk/artshums/depts/ddh/kiln/ns/1.0"
           xmlns:xsl="http://www.w3.org/1999/XSL/Transform">

  <!-- Imports stylesheet to convert TEI into HTML. -->
  <xsl:import href="cocoon://_internal/template/xsl/stylesheets/tei/inscription.xsl" />

  <kiln:parent>
    <xi:include href="base.xml" />
  </kiln:parent>

  <kiln:child>
    <kiln:block name="title">
      <xsl:value-of select="/aggregation/inscription/tei:TEI/tei:teiHeader/tei:fileDesc/tei:titleStmt/tei:title[not(@type)][@xml:lang=$lang]" />
    </kiln:block>

    <kiln:block name="page-pre-header">
      <xsl:call-template name="inscriptionnav" />
    </kiln:block>

    <kiln:block name="page-heading">
      <kiln:super />
      <xsl:call-template name="formatInscrNum">
        <xsl:with-param name="num" select="//tei:publicationStmt/tei:idno[@type='filename']"/>
        <xsl:with-param name="printCorpus" select="true()"/>
      </xsl:call-template>
      <xsl:text>. </xsl:text>
      <xsl:value-of select="/aggregation/inscription/tei:TEI/tei:teiHeader/tei:fileDesc/tei:titleStmt/tei:title[not(@type)][@xml:lang=$lang]" />
    </kiln:block>

    <kiln:block name="content">
      <div class="row">
        <div class="large-12 columns inscription">
          <!-- support -->
          <div class="row">
            <div class="large-2 columns">
              <!-- would be better in stylesheet -->
              <h2 ><xsl:value-of select="if ($lang='ru') then 'Камень' else 'Stone'"/></h2>
            </div>

            <div class="large-10 columns">
              <div class="row">
                <!-- Support is the only always-one element in the metadata -->
                <xsl:call-template name="inscriptionSupport" />
              </div>
            </div>

          </div>



          <xsl:apply-templates select="//inscription/tei:TEI//tei:body" />




          <!-- anything else -->
          <!-- <xsl:apply-templates select="//inscription/tei:TEI" /> -->

        </div>
      </div>
    </kiln:block>

    <kiln:block name="mainjs">
      <script src="{$kiln:assets-path}/scripts/vendor/requirejs/require.js"
              data-main="{$kiln:assets-path}/scripts/inscription" >&#160;</script>
    </kiln:block>
  </kiln:child>

</kiln:root>
