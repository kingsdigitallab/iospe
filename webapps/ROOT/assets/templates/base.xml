<?xml version="1.0" encoding="utf-8"?>
<kiln:root xmlns:kiln="http://www.kcl.ac.uk/artshums/depts/ddh/kiln/ns/1.0"
  xmlns:xi="http://www.w3.org/2001/XInclude" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">

  <!-- Imports the default variables. -->
  <xsl:import href="cocoon://_internal/template/xsl/stylesheets/defaults.xsl"/>

  <!-- Imports the menu stylesheet -->
  <xsl:import href="cocoon://_internal/template/xsl/stylesheets/menu/menu.xsl"/>

  <kiln:block name="html">
    <html class="no-js">
      <kiln:block name="head">
        <head>
          <meta charset="utf-8"/>
          <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
          <meta content="IE=edge,chrome=IE8" http-equiv="X-UA-Compatible"/>
          <title>
            <kiln:block name="title">Kiln: </kiln:block>
          </title>
          <kiln:block name="css">
            <link href="{$kiln:assets-path}/foundation/css/normalize.css" rel="stylesheet"
              type="text/css"/>
            <link href="{$kiln:assets-path}/foundation/css/foundation.min.css" rel="stylesheet"
              type="text/css"/>
            <link href="{$kiln:assets-path}/styles/base.css" rel="stylesheet" type="text/css"/>
            <link href="{$kiln:assets-path}/styles/site.css" rel="stylesheet" type="text/css"/>
          </kiln:block>
          <kiln:block name="js">
            <script src="{$kiln:assets-path}/foundation/js/vendor/custom.modernizr.js"
              >&#160;</script>

          </kiln:block>
          <kiln:block name="head-extra"/>
        </head>
      </kiln:block>
      <kiln:block name="body">
        <body data-lang="{$lang}">
          <div class="row">
            <div class="large-12 columns">
              <div id="banner" class="row">
                <div id="sea_of_loneliness" class="large-12 columns">
                  <a id="logo" class="right" href="{$kiln:context-path}/">
                    <img src="{$kiln:assets-path}/images/bs.h4.en.png" title="IOSPE"/>
                  </a>
                </div>
              </div>
              <div class="row">

                <div class="contain-to-grid">
                  <kiln:block name="navigation">
                    <nav class="top-bar">
                      <kiln:block name="main-navigation">
                        <ul class="title-area large-2">
                          <li class="name">
                            <a id="griffin" href="{$kiln:context-path}/"> &#160; </a>
                          </li>
                          <li class="toggle-topbar menu-icon right">
                            <a href="#">
                              <span>Menu</span>
                            </a>
                          </li>
                        </ul>
                        <section class="top-bar-section">
                          <ul class="left">
                            <xsl:apply-templates mode="main-menu" select="/aggregation/kiln:nav"/>
                          </ul>

                        </section>

                        <section class="top-bar-section">
                          <ul class="right language-choice">
                            <xsl:call-template name="menu-languages"/>
                          </ul>
                        </section>
                      </kiln:block>
                    </nav>
                  </kiln:block>
                </div>
                <!-- fixed and contained to the grid -->

              </div>
              <div id="body-wrapper" class="row">
                <div id="rock" class="large-2 columns">&#160;</div>

                <div id="main-content" class="large-10 columns ">
                  <kiln:block name="page-pre-header"/>
                  <kiln:block name="page-header">
                    <div class="row">
                      <div class="large-12 columns">
                        <h1>
                          <kiln:block name="page-heading"/>
                        </h1>
                      </div>
                    </div>
                  </kiln:block>
                  <kiln:block name="content-section">
                    <main>
                      <kiln:block name="content"/>
                    </main>
                  </kiln:block>
                </div>
              </div>
              <kiln:block name="footer">
                <footer>
                  <p>
                    <xsl:choose>
                      <xsl:when test="$lang='en'">
                        <a href="#logo" title="#">Top of Page</a>
                      </xsl:when>
                      <xsl:when test="$lang='ru'">
                        <a href="#logo" title="#">К началу страницы</a>
                      </xsl:when>
                    </xsl:choose>
                  </p>

                  <xsl:choose>
                    <xsl:when test="$lang='en'">
                      <p>&#xa9; 2011 King's College London</p>
                    </xsl:when>
                    <xsl:when test="$lang='ru'">
                      <p>&#xa9; 2011 Кингс Колледж Лондон</p>
                    </xsl:when>
                  </xsl:choose>
                </footer>
              </kiln:block>
              <kiln:block name="end-js">
                <!-- Since we make use of jQuery for other purposes, there
                     is no reason to use Foundation's check whether to use
                     jQuery or Zepto. -->
                <script src="{$kiln:assets-path}/foundation/js/vendor/jquery.js">&#160;</script>
                <script src="{$kiln:assets-path}/foundation/js/foundation.min.js">&#160;</script>
                <script src="{$kiln:assets-path}/foundation/js/foundation/foundation.dropdown.js"
                  >&#160;</script>
                <script src="{$kiln:assets-path}/foundation/js/foundation/foundation.topbar.js"
                  >&#160;</script>

                <kiln:block name="mainjs">
                  <script src="{$kiln:assets-path}/scripts/vendor/requirejs/require.js"
                    data-main="{$kiln:assets-path}/scripts/base">&#160;</script>
                </kiln:block>

                <script>$(document).foundation();</script>
              </kiln:block>
            </div>
            <!-- 12 (no columns) -->
          </div>
          <!-- row -->
        </body>
      </kiln:block>
    </html>
  </kiln:block>
</kiln:root>
