         <div type="translation" xml:lang="ru">
            <div type="textpart" n="1">
               <p>Господь Иисус, под<supplied reason="lost">ающий руку тонущему Петру</supplied>.</p>
            </div>
            <div type="textpart" n="2">
               <p>Господь Иисус, подающий ру<supplied reason="lost">ку Петру</supplied>.</p>
            </div>
         </div>
         <div type="translation" xml:lang="en">
            <div type="textpart" n="1">
               <p>Jesus Christ of<supplied reason="lost">fering his hand to drowning Peter</supplied>.</p>
            </div>
            <div type="textpart" n="2">
               <p>Jesus Christ offering <supplied reason="lost">his hand to Peter</supplied>.</p>
            </div>
