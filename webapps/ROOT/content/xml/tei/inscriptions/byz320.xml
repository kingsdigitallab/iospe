         <div type="apparatus" n="1">
             <p>
               <app loc="2-6"><rdg resp="b0132">θ[εοῦ ...] βαντζο[...] τοῦ δεκα[...] δε γεναμ[...] λόγου</rdg></app>
               <app loc="8"><rdg resp="b0132 b0046">ὥρ(ᾳ) ., ἰνδ.</rdg></app>
               <app loc="9"><rdg resp="b0132 b0046">ςυ[...</rdg></app>
            </p>
         </div>
         <div type="apparatus" n="2">
