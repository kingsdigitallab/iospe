<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="http://www.stoa.org/epidoc/schema/latest/tei-epidoc.rng" schematypens="http://relaxng.org/ns/structure/1.0"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0">
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>Authority list of divine names and epithets in IOSPE</title>
            </titleStmt>
            <publicationStmt><ab/></publicationStmt>
            <sourceDesc><ab/></sourceDesc>
        </fileDesc>
    </teiHeader>
    <text>
        <body>
            <div type="commentary">
                <listPerson type="divinities">
                    <head xml:lang="en">Divine and mythological figures</head>
                    <head xml:lang="ru">RU: Divine and mythological figures</head>
                    <person xml:id="adam">
                        <persName xml:lang="grc">Ἀδάμ</persName>
                    </person>
                    <person xml:id="theos">
                        <persName xml:lang="grc">Θεός</persName>
                        <persName xml:lang="grc">Σαβαώθ</persName>
                        <persName xml:lang="grc">Παντελεήμων</persName>
                    </person>
                    <person xml:id="maria">
                        <persName xml:lang="grc">Θεοτόκος</persName>
                   </person>
                    <person xml:id="iesous">
                        <persName xml:lang="grc">Ἰησοῦς Χριστός</persName>
                    </person>
                    <person sameAs="#iesous">
                        <persName xml:lang="grc">Κύριος</persName>
                    </person>
                    <person sameAs="#theos"><persName xml:lang="grc">Παντελεήμονος</persName></person>
                    <person sameAs="#theos"><persName xml:lang="grc">Σαβαώθ</persName></person>
                    <person sameAs="#iesous"><persName xml:lang="grc">Χριστός</persName></person>
                </listPerson>
                
                <listPerson type="saints">
                    <head xml:lang="en">Saints</head>
                    <head xml:lang="ru">RU: Saints</head>
                    <person xml:id="stgeorge">
                        <persName xml:lang="grc">Ἅγιος Γεώργιος</persName>
                    </person>
                    <person xml:id="stdimitrios">
                        <persName xml:lang="grc">Ἅγιος Δημήτριος</persName>
                    </person>
                    <person xml:id="sthelen">
                        <persName xml:lang="grc">Ἁγία Ἑλένη</persName>
                    </person>
                    <person xml:id="sttheodore">
                        <persName xml:lang="grc">Ἅγιος Θεόδωρος</persName>
                    </person>
                    <person xml:id="stjohn">
                        <persName xml:lang="grc">Ἅγιος Ἰωάννης</persName>
                    </person>
                    <person xml:id="stjohnbaptist">
                        <persName xml:lang="grc">Ἅγιος Ἰωάννης ὁ Πρόδρομος</persName>
                    </person>
                    <person xml:id="stjohnarchbishop">
                        <persName xml:lang="grc">Ἅγιος Ἰωάννης ἀρχιεπίσκοπος πόλεως Θε[ο]δώρους [καὶ] πάσης Γοτθίας</persName>
                    </person>
                    <person xml:id="stjohntheologos">
                        <persName xml:lang="grc">Ἅγιος Ἰωάννης ὁ Θεολόγος</persName>
                    </person>
                    <person xml:id="stcapiton">
                        <persName xml:lang="grc">Ἅγιος Καπίτων</persName>
                    </person>
                    <person xml:id="stconstantine">
                        <persName xml:lang="grc">Ἅγιος Κωνσταντῖνος</persName>
                    </person>
                        <person xml:id="stnicolas">
                        <persName xml:lang="grc">Ἅγιος Νικόλαος</persName>
                    </person>
                    <person xml:id="stpaul">
                        <persName xml:lang="grc">Ἅγιος Παύλος</persName>
                    </person>
                    <person xml:id="stpeter">
                        <persName xml:lang="grc">Ἅγιος Πέτρος</persName> 
                    </person>
                    <person xml:id="ststephen">
                        <persName xml:lang="grc">Ἅγιος Στέφανος</persName>
                    </person>
                </listPerson>
            </div>
