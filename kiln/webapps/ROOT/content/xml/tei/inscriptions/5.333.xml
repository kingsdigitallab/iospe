               <lb n="3"/><w lemma="ἔνθα">ἔν<supplied reason="lost">θα</supplied></w>
               <lb n="4"/><w lemma="κατάκειμαι"><supplied reason="lost" cert="low">κατά<lb n="5" break="no"/>κειται</supplied></w>
            </ab>
