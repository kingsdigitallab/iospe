                           <seg xml:lang="ru"/>
                           <seg xml:lang="en"/>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>
                        <seg xml:lang="ru">Πравая гаста альфа, дельта, лямбда иногда выступает за
                           пересечение с левой гастой; курсивные формы эпсилон, сигма, омега; слабое
                           апицирование.</seg>
                        <seg xml:lang="en"/>
                        <height unit="cm">1,0</height>
                     </handNote>
                  </handDesc>
