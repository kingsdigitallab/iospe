               <msContents>
                  <summary corresp="#doc4 #doc2">
                     <seg xml:lang="ru" n="1">Демонстративная надпись.</seg>
                     <seg xml:lang="en" n="1">Demonstrative.</seg>
                     <seg xml:lang="ru" n="2">Надгробная надпись.</seg>
                     <seg xml:lang="en" n="2">Epitaph.</seg>
                  </summary>
               </msContents>
               <physDesc>
                  <objectDesc>
                     <supportDesc>
                        <support>
                           <objectType xml:lang="ru" ref="monument-search.xml#mon3">Стела.</objectType>
                           <objectType xml:lang="en">Stele.</objectType>
                           <material xml:lang="ru" ref="material-search.xml#m2">Известняк.</material>
                           <material xml:lang="en">Limestone.</material>
                           <p xml:lang="ru">Стела с треугольным завершением; на лицевой стороне изображение креста в рамке вверху и филенка с тупоугольным 
                              завершением внизу, на тыльной стороне “коса” (высота 2) и орнамент на лицевой, боковых и тыльной сторонах. Разбита на 2 части.</p>
                           <p xml:lang="en">Stele with triangular top. On the front - relief cross within inset panel, and below - inscribed inset panel with triangular top; zigzag ornament
                           along the long sides. On the back - string-course (H 2cm). Additional ornaments on the ribs and back side of the stele. </p>
                           <dimensions>
                              <height>98,5</height>
                              <width>36,0</width>
                              <depth>20,0</depth>
                           </dimensions>
                        </support>
                     </supportDesc>
                     <layoutDesc>
                        <layout ana="f1" n="1">
                           <seg xml:lang="ru">В углах между рукавами креста.</seg>
                           <seg xml:lang="en">In corners between the arms of the cross.</seg>
                        </layout>
                        <layout ana="f1" n="2">
                           <seg xml:lang="ru">Внутри филенки.</seg>
                           <seg xml:lang="en">Inset panel below the cross.</seg>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote n="1">
                        <seg xml:lang="ru">См. ниже.</seg>
                        <seg xml:lang="en">See below.</seg>
                        <height unit="cm">0,7–2.</height>
                     </handNote>
                     <handNote n="2">
                        <seg xml:lang="ru"><rs type="execution" ref="execution.xml#scalpro">Лапидарный</rs>. Бета, дзета и лямбда минускульные, мю с Т-образной серединой, 
                           ню с зеркально повернутой перекладиной, ипсилон V-образный, омега с полукруглым низом. Лигатура, надстрочные знаки, сокращения.</seg>
                        <seg xml:lang="en">Lapidary. Minuscule beta, dzeta and lambda; mu with T-shaped crossbar, nu with mirrored diagonal, V-shaped ypsilon, bowl-shaped
                        omega. Ligature, superscript marks, abbreviations.</seg>
                        <height unit="cm">1,2.</height>
                     </handNote>
                  </handDesc>
