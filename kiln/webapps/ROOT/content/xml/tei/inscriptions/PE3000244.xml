            <ab>
               		<lb n="1"/><w>ἀγαθῇ</w> <w>τύ 
               		<lb n="2" break="no"/>χῃ</w> 
               		<lb n="3"/><w>θεᾷ</w> <persName type="attested"><name>Νεμέ
               		<lb n="4" break="no"/>σει</name> <name>Βασιλε 
               		<lb n="5" break="no"/>ίδης</name> <name>Καλοῦ</name></persName>.
            </ab>
