               <msContents>
                  <summary>
                     <seg xml:lang="ru" corresp="document-search.xml#doc2">Надгробная надпись.</seg>
                     <seg xml:lang="en">Epitaph.</seg>
                  </summary>
               </msContents>
               <physDesc>
                  <objectDesc>
                     <supportDesc>
                        <support>
                           <objectType xml:lang="ru" ref="monument-search.xml#mon3">Стела.</objectType>
                           <objectType xml:lang="en">Stele.</objectType>
                           <material xml:lang="ru" ref="material-search.xml#m2">Известняк.</material>
                           <material xml:lang="en">Limestone</material>
                           <p xml:lang="ru">Верхняя часть стелы, украшенной карнизом с антефиксами (частично сбиты). Расколота на две части. 
                              Тыльная сторона обработана суммарно. Лицевая грань с рельефными розетками. Под розетками изображение меча (вырезан отдельно и наклеен) и портупеи. 
                              Между карнизом и розетками черной краской нанесена двухстрочная надпись.</p>
                           <p xml:lang="en"/>
                           <dimensions>
                              <height unit="cm">81,0</height>
                              <width unit="cm">33,0</width>
                              <depth unit="cm">14,5</depth>
                           </dimensions>
                        </support>
                     </supportDesc>
                     <layoutDesc>
                        <layout>
                           <seg xml:lang="ru"/>
                           <seg xml:lang="en"/>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>
                        <seg xml:lang="ru">Ο немного меньше остальных букв, верхняя поперечная линия Π не выступает за короткую правую вертикаль, 
                           слегка изогнутые линии Α, Λ, Σ, утолщения на концах линий букв.</seg>
                        <seg xml:lang="en"/>
                        <height unit="cm">3,0</height>
                     </handNote>
                  </handDesc>
