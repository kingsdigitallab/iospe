            <!-- Комментарии -->
            <listBibl>
               <bibl><!--Даниленко 1966--><ptr target="bib:b0461"/>, 172</bibl>
               <bibl><!--Posamentir 2011--><ptr target="bib:b0439"/>, 32, № 21</bibl>
            </listBibl>
