            <!-- Издания -->
            <listBibl>
               <bibl><!--Соломоник 1969 --><ptr target="bib:b0504"/>, 65, № <citedRange>19</citedRange></bibl>
               <bibl><!--НЭПХ II--><ptr target="bib:НЭПХ2"/>, <citedRange>153</citedRange></bibl>
               <bibl><!--Perlman 2011--><ptr target="bib:b0437"/>, 433, № <citedRange>21</citedRange></bibl>
            </listBibl>
         </div>
