            <div type="translation" xml:lang="ru">
                <div type="textpart" n="1">
                    <p>Свет, жизнь.</p>
                </div>
                <div type="textpart" n="2">
                    <p>Иисус побеждает.</p>
                </div>
            <div type="textpart" n="3">
                <p>Спаси людия твоя и.</p>
            </div>
            <div type="textpart" n="4">
                <p>Господи, помоги рабу Твоему Константину грешнику.</p>
            </div>
            </div>
            <div type="translation" xml:lang="en">
                <div type="textpart" n="1">
                    <p>Light, life.</p>
                </div>
                <div type="textpart" n="2">
                    <p>Jesus is victorious.</p>
                </div>
                <div type="textpart" n="3">
                    <p>Save Thine people and.</p>
                </div>
                <div type="textpart" n="4">
                    <p>Lord, save your servant Konstantinos, a sinner.</p>
                </div>
            </div>

