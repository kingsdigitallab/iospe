               <lb n="3"/><persName type="divine" key="theos"><w lemma="θεός"><expan><abbr>θ</abbr><ex>εο</ex><abbr>ῦ</abbr></expan></w></persName> <persName type="attested" ref="#person206"><name nymRef="Εὐφήμιος">Ἐφύμιο<lb n="4" break="no"/>ς</name></persName> <date><w lemma="μήν"><expan><abbr>μη</abbr><ex>νὶ</ex></expan></w> <rs type="month" ref="mar"><w lemma="Μάρτιος">Μαρτίου</w></rs>
