<?xml version="1.0" encoding="utf-8"?>
<kiln:root xmlns:tei="http://www.tei-c.org/ns/1.0" xmlns:xi="http://www.w3.org/2001/XInclude"
    xmlns:kiln="http://www.kcl.ac.uk/artshums/depts/ddh/kiln/ns/1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:i18n="http://apache.org/cocoon/i18n/2.1">
    
    <!-- Imports inscription stylesheet . -->
    <xsl:import href="cocoon://_internal/template/xsl/stylesheets/tei/tocs-volumes.xsl"/>
    
    <xsl:param name="url"/>
    
    <xsl:variable name="seq">
        <xsl:sequence select="/aggregation/toc/response/result"/>
    </xsl:variable>
    
    <kiln:parent>
        <xi:include href="tocs.xml"/>
    </kiln:parent>
    
    
    <kiln:child>
        
        <kiln:block name="title">
            <kiln:super/>
            <xsl:call-template name="tocVolumeTitle"/>
        </kiln:block>
        
        
        <kiln:block name="page-heading">
            <kiln:super/>
            <xsl:call-template name="tocVolumeTitle"/>
        </kiln:block>
        
        <kiln:block name="content">
            <kiln:super/>
            <xsl:choose>
                <xsl:when test="starts-with($url, '1')">
                    <dl class="indices indices-locations tocs">
                        <dt>
                            <i18n:text>State decrees honouring citizens</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.1', '1.2', '1.3', '1.4')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>State decrees honouring foreigners</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.5')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>State decrees</i18n:text>. Varia
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.6', '1.7', '1.8', '1.9', '1.10')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Public Inscriptions other than decrees</i18n:text><br /> &#x2014; <i18n:text>Letters of state officials</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.12', '1.13', '1.14')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Public inscriptions of uncertain type</i18n:text> (Varia)
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.15', '1.16')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Dedicatory and other inscriptions with religious content</i18n:text><br /> &#x2014; <i18n:text>Dedications of private individuals</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.17', '1.18', '1.19', '1.20', '1.21', '1.22')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Building inscriptions</i18n:text><br /> &#x2014; <i18n:text>Building inscriptions of rulers and officials</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.23', '1.24', '1.25')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Honorary inscriptions</i18n:text><br /> &#x2014; <i18n:text>Inscriptions honouring Roman emperors and their family members</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.26', '1.27', '1.28')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Inscriptions honouring citizens</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.29')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Honorary inscriptions</i18n:text>. Varia
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.30')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Lists of names</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.31')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Epitaphs</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.32', '1.33', '1.34', '1.35', '1.36', '1.37')"/>
                        </xsl:call-template>
                        <dt>
                            <i18n:text>Inscriptions on weights</i18n:text>
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.38', '1.39')"/>
                        </xsl:call-template>
                        <dt>
                            Varia
                        </dt>
                        <xsl:call-template name="generateTOCItems">
                            <xsl:with-param name="values" select="('1.40', '1.41', '1.42', '1.43', '1.44', '1.45', '1.46', '1.47', '1.48', '1.49', '1.50', '1.51', '1.52', '1.53', '1.54', '1.55', '1.56', '1.57', '1.58', '1.59', '1.60', '1.61', '1.62', '1.63', '1.64', '1.65', '1.66', '1.67', '1.68', '1.69')"/>
                        </xsl:call-template>
                    </dl>
                </xsl:when>
                <xsl:when test="starts-with($url, '3')">
                    <xsl:call-template name="generateVolumeToc"/>
                </xsl:when>
            </xsl:choose>
            
        </kiln:block>
        
    </kiln:child>
    
</kiln:root>

